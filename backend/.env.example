# Copia este archivo como .env y completa los valores reales.
# NUNCA versiones el archivo .env en el repositorio.

# API Key de OpenRouter (https://openrouter.ai) - usada por las dos IAs (FrontDeskAI y ActionAI)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modelo usado por la IA conversacional (atiende al paciente)
FRONT_DESK_MODEL=openrouter/free

# Modelo usado por la IA de extraccion/ejecucion de acciones (salida JSON estricta)
ACTION_MODEL=openrouter/free

# Cadena de conexion a la base de datos. SQLite por defecto para desarrollo;
# puede cambiarse a Postgres (postgresql+psycopg2://user:pass@host/db) sin tocar el codigo.
DATABASE_URL=sqlite:///./clinicflow.db

# Secreto usado para firmar los tokens JWT de autenticacion. Genera uno propio
# para produccion, por ejemplo con: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=clinicflow-dev-secret-do-not-use-in-production

# Token del bot de Telegram (obtener de @BotFather en Telegram)
# Requerido solo si vas a ejecutar telegram_bot.py
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
